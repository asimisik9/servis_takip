# App
ENVIRONMENT=development
SECRET_KEY=change_this_to_a_very_secure_random_string_in_production
REFRESH_SECRET_KEY=change_this_to_a_different_secure_random_string

# Database
POSTGRES_USER=isikasimm
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=my-postgres-db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Google Maps API (For route optimization)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# SMTP / Password Reset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey_or_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_URL_BASE=https://app.example.com/reset-password
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
EMAIL_VERIFY_REDIRECT_URL=https://app.example.com/verify-email

# Initial Superuser
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=ChangeThisToSecurePassword123!

# CORS (Comma separated)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174
